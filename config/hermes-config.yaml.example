# deepseekrescue — Hermes Agent configuration
# Key is auto-injected by build.sh from active Amsterdam config

default_provider: deepseek
default_model: deepseek-chat

fallback_providers:
  - deepseek

gateway:
  enabled: false

tools:
  enabled: true

providers:
  deepseek:
    api_key: "DEEPSEEK_API_KEY_HERE"
  custom:
    api_key: "local"
    base_url: "http://127.0.0.1:8080/v1"

models:
  deepseek:
    deepseek-v4-flash:
      provider: deepseek
    deepseek-v3-0324:
      provider: deepseek
    deepseek-r1:
      provider: deepseek
  custom:
    local-model:
      provider: custom
